{
  "version": 2,
  "crons": [
    {
      "path": "/api/scheduler/assign-pools",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/scheduler/assign-pools",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/scheduler/send-reminders",
      "schedule": "0 8 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/scheduler/(.*)",
      "headers": [
        {
          "key": "X-API-Key",
          "value": "${env.NEXT_PUBLIC_API_KEY}"
        },
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ]
}